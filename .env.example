# ================================================
# WhatsApp Inbox — DR.TRÁFEGO
# Copie para .env.local e preencha os valores
# ================================================

# Auth
AUTH_SECRET=gere-com-openssl-rand-hex-32

# Supabase (Settings → Database → Connection string → URI — use o Pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta / WhatsApp Cloud API
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# n8n
N8N_WEBHOOK_URL=https://n8n.seudominio.com/webhook/whatsapp-bot

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# App
NEXT_PUBLIC_APP_URL=https://seudominio.com.br

# Stripe (opcional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
